# --------------------------------------------------------------------------------------
# Fabric workspace
# --------------------------------------------------------------------------------------
FABRIC_WORKSPACE_NAME="FrasoHome Fabric RAG Demo"
FABRIC_WORKSPACE_ID="4d585ddf-d206-47c0-bceb-332ed71adbb0"
FABRIC_TENANT_ID="c2c0e5ea-f0e8-4934-8f1c-d8260ba230d7"

# --------------------------------------------------------------------------------------
# SQL Database in Microsoft Fabric
# Crear con scripts/deploy_fabric_sql.ps1 en Windows y copiar el server name desde Connection strings.
# --------------------------------------------------------------------------------------
FABRIC_SQL_DATABASE_NAME="FrasoHomeRagDB"
FABRIC_SQL_SERVER="tcp:<server>.database.fabric.microsoft.com,1433"
FABRIC_SQL_DATABASE_ITEM_ID=""

# --------------------------------------------------------------------------------------
# User Data Functions
# --------------------------------------------------------------------------------------
FABRIC_UDF_ITEM_NAME="FrasoHome_RAG_UDF"
FABRIC_UDF_SQL_ALIAS="frasohome_sql"
VITE_UDF_FUNCTION_URL=""

# --------------------------------------------------------------------------------------
# Frontend Entra/MSAL for calling UDF public endpoint
# --------------------------------------------------------------------------------------
VITE_ENTRA_CLIENT_ID="00000000-0000-0000-0000-000000000000"
VITE_ENTRA_TENANT_ID="00000000-0000-0000-0000-000000000000"

# --------------------------------------------------------------------------------------
# Demo embeddings / optional LLM integration
# --------------------------------------------------------------------------------------
RAG_EMBEDDING_DIMENSIONS="64"
RAG_USE_EXTERNAL_MODELS="false"
AZURE_OPENAI_ENDPOINT=""
AZURE_OPENAI_API_KEY=""
AZURE_OPENAI_EMBEDDING_DEPLOYMENT=""
AZURE_OPENAI_CHAT_DEPLOYMENT=""
AZURE_OPENAI_API_VERSION="2024-10-21"
