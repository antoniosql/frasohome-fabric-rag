# --------------------------------------------------------------------------------------
# Fabric workspace
# --------------------------------------------------------------------------------------
FABRIC_WORKSPACE_NAME="FrasoHome Fabric RAG Demo"
FABRIC_WORKSPACE_ID="00000000-0000-0000-0000-000000000000"
FABRIC_TENANT_ID="00000000-0000-0000-0000-000000000000"

# --------------------------------------------------------------------------------------
# Non-interactive auth for Fabric CLI and SQL automation
# --------------------------------------------------------------------------------------
# Fabric CLI (`fab`) understands the FAB_* variables directly when they are present.
# Options:
# - Service principal secret: set FAB_TENANT_ID, FAB_SPN_CLIENT_ID, FAB_SPN_CLIENT_SECRET.
# - Service principal certificate: set FAB_TENANT_ID, FAB_SPN_CLIENT_ID, FAB_SPN_CERT_PATH
#   and optionally FAB_SPN_CERT_PASSWORD.
# - Federated credential: set FAB_TENANT_ID, FAB_SPN_CLIENT_ID, FAB_SPN_FEDERATED_TOKEN.
# - Managed identity: set FAB_MANAGED_IDENTITY="true"; for user-assigned identity also set
#   FAB_SPN_CLIENT_ID to the managed identity client id.
FAB_TENANT_ID="00000000-0000-0000-0000-000000000000"
FAB_SPN_CLIENT_ID="00000000-0000-0000-0000-000000000000"
FAB_SPN_CLIENT_SECRET=""
FAB_SPN_CERT_PATH=""
FAB_SPN_CERT_PASSWORD=""
FAB_SPN_FEDERATED_TOKEN=""
FAB_MANAGED_IDENTITY=""

# SQL script authentication for sqlcmd. Use one of:
# - default: sqlcmd ActiveDirectoryDefault chain.
# - service-principal: FAB_SPN_CLIENT_ID + FAB_SPN_CLIENT_SECRET.
# - managed-identity: system-assigned MI, or user-assigned MI with FABRIC_SQL_MANAGED_IDENTITY_CLIENT_ID.
FABRIC_SQL_AUTH_MODE="service-principal"
FABRIC_SQL_MANAGED_IDENTITY_CLIENT_ID=""

# Console UDF test authentication. Uses the same FAB_* values by default.
FABRIC_UDF_AUTH_MODE="service-principal"
FABRIC_UDF_MANAGED_IDENTITY_CLIENT_ID=""

# --------------------------------------------------------------------------------------
# SQL Database in Microsoft Fabric
# Crear con scripts/deploy_fabric_sql.ps1 en Windows y copiar el server name desde Connection strings.
# --------------------------------------------------------------------------------------
FABRIC_SQL_DATABASE_NAME="FrasoHomeRagDB"
FABRIC_SQL_SERVER="tcp:<server>.database.fabric.microsoft.com,1433"
FABRIC_SQL_DATABASE_ITEM_ID=""

# --------------------------------------------------------------------------------------
# User Data Functions
# --------------------------------------------------------------------------------------
FABRIC_UDF_ITEM_NAME="FrasoHome_RAG_UDF"
FABRIC_UDF_SQL_ALIAS="frasohome_sql"
VITE_UDF_FUNCTION_URL=""

# --------------------------------------------------------------------------------------
# Frontend Entra/MSAL for calling UDF public endpoint
# --------------------------------------------------------------------------------------
VITE_ENTRA_CLIENT_ID="00000000-0000-0000-0000-000000000000"
VITE_ENTRA_TENANT_ID="00000000-0000-0000-0000-000000000000"

# --------------------------------------------------------------------------------------
# Demo embeddings / optional LLM integration
# --------------------------------------------------------------------------------------
RAG_EMBEDDING_DIMENSIONS="64"
RAG_USE_EXTERNAL_MODELS="false"
AZURE_OPENAI_ENDPOINT=""
AZURE_OPENAI_API_KEY=""
AZURE_OPENAI_EMBEDDING_DEPLOYMENT=""
AZURE_OPENAI_CHAT_DEPLOYMENT=""
AZURE_OPENAI_API_VERSION="2024-10-21"
